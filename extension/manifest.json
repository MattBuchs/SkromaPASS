{
	"manifest_version": 3,
	"name": "SkromaPASS",
	"version": "1.0.0",
	"description": "Gestionnaire de mots de passe sécurisé avec auto-remplissage",
	"permissions": ["storage", "activeTab", "tabs", "notifications"],
	"host_permissions": ["https://skromapass.com/*"],
	"background": {
		"service_worker": "background.js"
	},
	"content_scripts": [
		{
			"matches": ["<all_urls>"],
			"js": [
				"src/content/content-utils.js",
				"src/content/content-forms.js",
				"src/content/content-autofill.js",
				"src/content/content-generator.js",
				"src/content/content-save.js",
				"src/content/content-styles.js",
				"content.js"
			],
			"run_at": "document_idle",
			"all_frames": true
		}
	],
	"action": {
		"default_popup": "popup.html",
		"default_icon": {
			"16": "icons/icon16.png",
			"32": "icons/icon32.png",
			"48": "icons/icon48.png",
			"128": "icons/icon128.png"
		}
	},
	"icons": {
		"16": "icons/icon16.png",
		"32": "icons/icon32.png",
		"48": "icons/icon48.png",
		"128": "icons/icon128.png"
	},
	"web_accessible_resources": [
		{
			"resources": ["injected.js"],
			"matches": ["<all_urls>"]
		}
	],
	"commands": {
		"_execute_action": {
			"suggested_key": {
				"default": "Ctrl+I"
			},
			"description": "Ouvrir SkromaPASS"
		},
		"autofill-current-site": {
			"suggested_key": {
				"default": "Alt+Shift+F"
			},
			"description": "Auto-remplir le formulaire actuel"
		}
	}
}
